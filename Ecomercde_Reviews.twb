      <aliases enabled='yes' />
      <column caption='Pending Response %' datatype='real' name='[Calculation_0931603234664457]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Response_Status]= &apos;Pending&apos; THEN [Order_ID] END) / COUNTD([Order_ID])' />
      </column>
      <column caption='Positive Reviews' datatype='real' name='[Calculation_0931603246948362]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Sentiment_Label]=&apos;Positive&apos; THEN [Order_ID] END)/COUNTD([Order_ID])' />
      </column>
      <column caption='Negative Statment' datatype='real' name='[Calculation_0931603248406539]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Sentiment_Label] = &apos;Negative&apos; THEN [Order_ID] END) / COUNTD([Order_ID])' />
      </column>
      <column caption='Net Sentimen Score' datatype='real' name='[Calculation_0931603249623052]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(COUNTD(IF [Sentiment_Label] = &apos;Positive&apos; THEN [Order_ID] END) - COUNTD(IF [Sentiment_Label] = &apos;Negative&apos; THEN [Order_ID] END)) / COUNTD([Order_ID])' />
      </column>
